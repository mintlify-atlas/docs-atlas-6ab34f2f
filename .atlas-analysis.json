  "keyFeatures": [
    "Real-time AVL tree visualization using D3.js rendered as SVG",
    "Socket.IO integration for live communication with a Python backend",
    "Add obstacles manually (type, X/Y coordinates) or bulk-load from a JSON file",
    "Tree traversal visualization: pre-order, in-order, and post-order",
    "Delete/remove obstacles from the AVL tree with coordinate-based lookup",
    "Animated SVG car sprite with dynamic color customization",
    "Bootstrap Vapor dark-theme SPA with no page reloads",
    "Road width configuration before starting obstacle management"
  ],
