{
  "projectType": "frontend",
  "projectName": "AVL Tree Car Front",
  "projectDescription": "A single-page application that visualizes an AVL tree of road obstacles in real time, communicating with a Python backend over Socket.IO to insert, remove, and traverse obstacles using pre-order, in-order, and post-order traversals.",
  "theme": "palm",
  "primaryColor": "#6900be",
  "lightColor": "#a855f7",
  "darkColor": "#040116",
